{
  "name": "byignis/greenter-api",
  "description": "Microservicio REST para facturación electrónica SUNAT usando Greenter",
  "type": "project",
  "require": {
    "php": "^8.2",
    "greenter/greenter": "^4.0",
    "slim/slim": "^4.0",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "monolog/monolog": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
